    // Create/update entries for each patch
    // remaining = patch.remaining_seconds (from server)
}

// setInterval(tick, 1000) — global 1-second ticker
function tick() {
    for (const [id, t] of Object.entries(timers)) {
        t.remaining -= 1;
        if (t.remaining <= 0) {
