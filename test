#Add TACACS+
#TACACS+ Configuration
config admin aaa-server-group tacplus {TACACS Group Name, e.g., Group-1}
config admin aaa-servers tacplus add TAC1 {IPv6 TACACS server address} timeout 3 single-connect enabled
yes
{TACACS Secret}
{TACACS Secret}
config admin aaa-servers tacplus add TAC2 {IPv6 TACACS server address} timeout 3 single-connect enabled
yes
{TACACS Secret}
{TACACS Secret}
config admin aaa-servers tacplus modify TAC1 source-address {Node IP}
config admin aaa-servers tacplus modify TAC2 source-address {Node IP}
config admin aaa-server-group tacplus {TACACS Group Name, e.g., Group-1} add server TAC1 priority 14
config admin aaa-server-group tacplus {TACACS Group Name, e.g., Group-1} add server TAC2 priority 14
config admin authorization tacplus add server-group {TACACS Group Name, e.g., Group-1}
config admin authentication tacplus add server-group {TACACS Group Name, e.g., Group-1}
config admin authorization tacplus type priv-lvl
#
#Configure Syslog
config admin syslog 1 ip {IPv6 Address}
config admin syslog 1 port {514}
config admin syslog 1 priority debug
config admin syslog 1 status enabled
config admin syslog 2 ip {IPv6 Address}
config admin syslog 2 port {514}
config admin syslog 2 priority debug
config admin syslog 2 status enabled
#
#Change acl_default Action
config acl_default defaultRxAction block
yes
#
#Add SNMP community string
config snmpserver community {level} {string}
