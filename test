```

### Client-side: Power Reading Thresholds

```javascript
function powerColor(dbm) {
    if (dbm === null || dbm === undefined) return '#9e9e9e';  // grey — no reading
    if (dbm > -10)  return '#4caf50';  // green — good signal
    if (dbm >= -30) return '#ffc107';  // yellow — marginal
    return '#f44336';                  // red — poor signal
}
```

